---
import PageLayout from "../../layouts/PageLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);
---

<PageLayout title="Projects" description="Selected projects and open source work.">
  <h1
    style="font-family: var(--font-sans); font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem;"
  >
    Projects
  </h1>
  <p style="color: var(--color-text-secondary); margin: 0 0 1.5rem; font-size: 0.9375rem;">
    Selected projects and open source work.
  </p>

  {projects.map((project) => <ProjectCard project={project} />)}
</PageLayout>
