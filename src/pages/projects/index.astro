---
import PageLayout from "../../layouts/PageLayout.astro"
import ProjectCard from "../../components/ProjectCard.astro"
import { getCollection } from "astro:content"

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
)
---

<PageLayout
  title="Projects"
  description="Selected projects and open source work."
>
  <h1
    style="font-family: var(--font-sans); font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem;"
  >
    Projects
  </h1>
  <p
    style="color: var(--color-text-secondary); margin: 0 0 1.5rem; font-size: 0.9375rem;"
  >
    Selected projects and open source work.
  </p>

  {
    projects.length > 0 ? (
      projects.map((project) => <ProjectCard project={project} />)
    ) : (
      <p style="color: var(--color-text-muted); font-size: 0.9375rem;">
        No projects yet. Add a markdown file to{" "}
        <code style="font-family: var(--font-mono); font-size: 0.875em;">
          src/data/projects/
        </code>{" "}
        to get started.
      </p>
    )
  }
</PageLayout>
