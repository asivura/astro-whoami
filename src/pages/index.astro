---
import PageLayout from "../layouts/PageLayout.astro"
import JsonLd from "../components/JsonLd.astro"
import { siteConfig } from "../site.config"

const socialSameAs = Object.values(siteConfig.social)

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: siteConfig.name,
      url: siteConfig.url,
      description: siteConfig.description,
    },
    {
      "@type": "Person",
      name: siteConfig.author.name,
      url: siteConfig.url,
      jobTitle: siteConfig.jsonLd.jobTitle,
      worksFor: {
        "@type": "Organization",
        ...siteConfig.jsonLd.worksFor,
      },
      sameAs: socialSameAs,
    },
  ],
}
---

<PageLayout>
  <JsonLd data={jsonLd} slot="head" />

  <section style="margin: 2rem 0 3rem;">
    <h1
      style="font-family: var(--font-sans); font-size: 1.5rem; font-weight: 600; margin: 0 0 1rem;"
    >
      {siteConfig.homepage.greeting}
    </h1>
    <p
      style="font-size: 1.0625rem; color: var(--color-text-secondary); line-height: 1.7; margin: 0;"
    >
      {siteConfig.homepage.intro}
    </p>
  </section>

  <section style="margin-bottom: 3rem;">
    <h2
      style="font-family: var(--font-sans); font-size: 0.875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin: 0 0 1rem;"
    >
      Featured Writing
    </h2>
    <ul
      style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem;"
    >
      {
        siteConfig.homepage.featured.map((item) => (
          <li>
            <a
              href={item.href}
              style="color: var(--color-text); text-decoration: underline; text-decoration-color: var(--color-text-muted); text-underline-offset: 3px; text-decoration-thickness: 1px; font-size: 1.0625rem;"
            >
              {item.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2
      style="font-family: var(--font-sans); font-size: 0.875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin: 0 0 1rem;"
    >
      Connect
    </h2>
    <div
      style="display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.9375rem;"
    >
      {
        Object.entries(siteConfig.social).map(([name, url]) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            style="color: var(--color-text-secondary); text-decoration: none; text-transform: capitalize;"
          >
            {name}
          </a>
        ))
      }
      <a
        href={`mailto:${siteConfig.author.email}`}
        style="color: var(--color-text-secondary); text-decoration: none;"
      >
        Email
      </a>
    </div>
  </section>
</PageLayout>
