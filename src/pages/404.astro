---
import PageLayout from "../layouts/PageLayout.astro"
---

<PageLayout title="Not Found">
  <div style="text-align: center; padding: 4rem 0;">
    <h1
      style="font-family: var(--font-sans); font-size: 3rem; font-weight: 600; margin: 0 0 1rem; color: var(--color-text-muted);"
    >
      404
    </h1>
    <p
      style="color: var(--color-text-secondary); font-size: 1.0625rem; margin: 0 0 2rem;"
    >
      This page doesn't exist.
    </p>
    <a
      href="/"
      style="font-family: var(--font-sans); font-size: 0.9375rem; color: var(--color-text); text-decoration: underline; text-underline-offset: 3px;"
    >
      Go home
    </a>
  </div>
</PageLayout>
