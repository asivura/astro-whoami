---
import PageLayout from "../layouts/PageLayout.astro"
import JsonLd from "../components/JsonLd.astro"
import { siteConfig } from "../site.config"

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.url,
    jobTitle: siteConfig.jsonLd.jobTitle,
    worksFor: {
      "@type": "Organization",
      ...siteConfig.jsonLd.worksFor,
    },
    sameAs: Object.values(siteConfig.social),
  },
}
---

<PageLayout title="About" description={`About ${siteConfig.author.name}`}>
  <JsonLd data={jsonLd} slot="head" />

  <h1
    style="font-family: var(--font-sans); font-size: 1.5rem; font-weight: 600; margin: 0 0 1.5rem;"
  >
    About
  </h1>

  <div class="prose">
    <p>
      I'm a software engineer with a focus on building tools that make
      developers more productive. I've spent the past decade working across the
      stack, from infrastructure and data pipelines to frontend interfaces and
      developer experience.
    </p>

    <p>
      Currently, I'm working at Example Corp, where I build AI-powered developer
      tools. Before that, I spent time at startups and larger companies, always
      gravitating toward problems at the intersection of engineering and user
      experience.
    </p>

    <h2>What I Work With</h2>

    <p>
      My day-to-day involves TypeScript, Python, and whatever tool best fits the
      problem. I care about clean APIs, fast feedback loops, and systems that
      are easy to reason about.
    </p>

    <p>Technologies I use regularly:</p>
    <ul>
      <li>TypeScript, Python, Go</li>
      <li>React, Astro, Next.js</li>
      <li>PostgreSQL, Redis</li>
      <li>Docker, Kubernetes</li>
      <li>AWS, GCP</li>
    </ul>

    <h2>Beyond Code</h2>

    <p>
      I write about software engineering, design, and the tools I use. I believe
      in learning in public and sharing what I know. This site is part of that
      practice.
    </p>

    <p>
      You can reach me at <a href={`mailto:${siteConfig.author.email}`}
        >{siteConfig.author.email}</a
      > or find me on any of the platforms linked in the footer.
    </p>
  </div>
</PageLayout>
