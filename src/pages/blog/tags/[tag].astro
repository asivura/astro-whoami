---
import PageLayout from "../../../layouts/PageLayout.astro"
import PostList from "../../../components/PostList.astro"
import { getCollection } from "astro:content"

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft)
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))]
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }))
}

const { tag, posts } = Astro.props
---

<PageLayout
  title={`Posts tagged "${tag}"`}
  description={`Blog posts tagged with ${tag}.`}
>
  <h1
    style="font-family: var(--font-sans); font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem;"
  >
    Tagged &ldquo;{tag}&rdquo;
  </h1>
  <p
    style="color: var(--color-text-secondary); margin: 0 0 2rem; font-size: 0.9375rem;"
  >
    <a href="/blog" style="font-family: var(--font-sans);">&larr; All posts</a>
  </p>

  <PostList posts={posts} />
</PageLayout>
