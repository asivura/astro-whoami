---
import PageLayout from "../../layouts/PageLayout.astro"
import PostList from "../../components/PostList.astro"
import { getCollection } from "astro:content"

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<PageLayout
  title="Blog"
  description="Thoughts on engineering, design, and building for the web."
>
  <h1
    style="font-family: var(--font-sans); font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem;"
  >
    Blog
  </h1>
  <p
    style="color: var(--color-text-secondary); margin: 0 0 2rem; font-size: 0.9375rem;"
  >
    Thoughts on engineering, design, and building for the web.
  </p>

  {
    posts.length > 0 ? (
      <PostList posts={posts} />
    ) : (
      <p style="color: var(--color-text-muted); font-size: 0.9375rem;">
        No posts yet. Add a markdown file to{" "}
        <code style="font-family: var(--font-mono); font-size: 0.875em;">
          src/data/blog/
        </code>{" "}
        to get started.
      </p>
    )
  }
</PageLayout>
