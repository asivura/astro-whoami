---
interface Props {
  project: {
    data: {
      title: string;
      description: string;
      techStack: string[];
      url?: string;
      repo?: string;
      status: string;
      period?: string;
    };
    body?: string;
  };
}

const { project } = Astro.props;
const { title, description, techStack, url, repo, period } = project.data;
const link = url || repo;
---

<article style="padding: 1.25rem 0; border-bottom: 1px solid var(--color-border);">
  <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem;">
    {link ? (
      <h3 style="margin: 0; font-size: 1.0625rem; font-weight: 600; font-family: var(--font-sans);">
        <a href={link} target="_blank" rel="noopener noreferrer" style="color: var(--color-text); text-decoration: none;">
          {title}
        </a>
      </h3>
    ) : (
      <h3 style="margin: 0; font-size: 1.0625rem; font-weight: 600; font-family: var(--font-sans); color: var(--color-text);">
        {title}
      </h3>
    )}
    {period && (
      <span style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-sans); white-space: nowrap;">
        {period}
      </span>
    )}
  </div>
  <p style="margin: 0.375rem 0 0.625rem; font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.5;">
    {description}
  </p>
  {techStack.length > 0 && (
    <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
      {techStack.map((tech) => (
        <span style="font-family: var(--font-sans); font-size: 0.75rem; padding: 0.15rem 0.5rem; border-radius: 9999px; background-color: var(--color-tag-bg); color: var(--color-tag-text);">
          {tech}
        </span>
      ))}
    </div>
  )}
</article>
