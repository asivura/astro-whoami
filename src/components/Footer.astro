---
import { siteConfig } from "../site.config"

const year = new Date().getFullYear()
const socialEntries = Object.entries(siteConfig.social)
---

<footer
  style="border-top: 1px solid var(--color-border); margin-top: 4rem; padding: 2rem 0; font-family: var(--font-sans);"
>
  <div
    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; font-size: 0.875rem; color: var(--color-text-muted);"
  >
    <span>&copy; {year} {siteConfig.name}</span>
    <div style="display: flex; gap: 1rem;">
      {
        socialEntries.map(([name, url]) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            style="color: var(--color-text-muted); text-decoration: none; text-transform: capitalize;"
          >
            {name}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        style="color: var(--color-text-muted); text-decoration: none;"
      >
        RSS
      </a>
    </div>
  </div>
</footer>
