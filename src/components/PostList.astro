---
import FormattedDate from "./FormattedDate.astro"

interface Props {
  posts: Array<{
    id: string
    data: {
      title: string
      pubDate: Date
      description: string
      tags?: string[]
    }
  }>
}

const { posts } = Astro.props
---

<ul style="list-style: none; padding: 0; margin: 0;">
  {
    posts.map((post) => (
      <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
        <div style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem;">
          <a
            href={`/blog/${post.id}`}
            style="font-size: 1.0625rem; text-decoration: none; color: var(--color-text);"
          >
            {post.data.title}
          </a>
          <span style="font-size: 0.8125rem; color: var(--color-text-muted); font-family: var(--font-sans); white-space: nowrap;">
            <FormattedDate date={post.data.pubDate} />
          </span>
        </div>
        <p style="margin: 0.25rem 0 0; font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.5;">
          {post.data.description}
        </p>
        {post.data.tags && post.data.tags.length > 0 && (
          <div style="display: flex; gap: 0.375rem; flex-wrap: wrap; margin-top: 0.5rem;">
            {post.data.tags.map((tag) => (
              <a
                href={`/blog/tags/${tag}`}
                style="font-family: var(--font-sans); font-size: 0.75rem; padding: 0.125rem 0.5rem; background-color: var(--color-tag-bg); color: var(--color-tag-text); border-radius: 9999px; text-decoration: none;"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </li>
    ))
  }
</ul>
