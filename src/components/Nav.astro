---
import { siteConfig } from "../site.config"
import ThemeToggle from "./ThemeToggle.astro"

const currentPath = Astro.url.pathname
---

<nav
  aria-label="Main navigation"
  style="display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 0; font-family: var(--font-sans);"
>
  <a
    href="/"
    style="text-decoration: none; font-weight: 600; font-size: 1.0625rem; color: var(--color-text);"
  >
    {siteConfig.name}
  </a>
  <div style="display: flex; align-items: center; gap: 1.25rem;">
    {
      siteConfig.nav.map((item) => (
        <a
          href={item.href}
          style={`text-decoration: none; font-size: 0.9375rem; transition: color 0.2s ease; color: ${currentPath.startsWith(item.href) ? "var(--color-text)" : "var(--color-text-secondary)"};`}
        >
          {item.label}
        </a>
      ))
    }
    <ThemeToggle />
  </div>
</nav>
