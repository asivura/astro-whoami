---
import PageLayout from "./PageLayout.astro"
import JsonLd from "../components/JsonLd.astro"
import FormattedDate from "../components/FormattedDate.astro"
import { siteConfig } from "../site.config"

interface Props {
  title: string
  description: string
  pubDate: Date
  updatedDate?: Date
  tags?: string[]
  ogImage?: string
  canonicalUrl?: string
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  ogImage,
  canonicalUrl,
} = Astro.props

const postUrl = new URL(Astro.url.pathname, siteConfig.url).href

const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  ...(tags && tags.length > 0 && { keywords: tags }),
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.url,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
}
---

<PageLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
>
  <JsonLd data={blogPostingLd} slot="head" />
  <article>
    <header style="margin-bottom: 2rem;">
      <h1
        style="font-family: var(--font-sans); font-size: 1.875rem; font-weight: 600; line-height: 1.2; margin: 0 0 0.5rem;"
      >
        {title}
      </h1>
      <div
        style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: var(--color-text-muted); font-family: var(--font-sans);"
      >
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span>
              (updated <FormattedDate date={updatedDate} />)
            </span>
          )
        }
      </div>
      {
        tags && tags.length > 0 && (
          <div style="display: flex; gap: 0.375rem; flex-wrap: wrap; margin-top: 0.75rem;">
            {tags.map((tag) => (
              <a
                href={`/blog/tags/${tag}`}
                style="font-family: var(--font-sans); font-size: 0.75rem; padding: 0.125rem 0.5rem; background-color: var(--color-tag-bg); color: var(--color-tag-text); border-radius: 9999px; text-decoration: none;"
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</PageLayout>
